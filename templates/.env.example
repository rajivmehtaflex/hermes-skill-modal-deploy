# Modal resource configuration
# Auth is handled by ~/.modal.toml (run: .venv/bin/modal setup)
#
# GPU, CPU, and RAM are INDEPENDENT — setting a GPU does not auto-configure
# CPU (default: 0.125 cores) or RAM (default: 128 MB). Set all of them.

# CPU cores (default if unset: 0.125 — very slow)
MODAL_CPU=8.0

# Memory in MB (16 GB = 16384; default if unset: 128 MB)
MODAL_MEMORY=16384

# Timeout in seconds (6h = 21600)
MODAL_TIMEOUT=21600

# Number of GPUs (0 = no GPU)
MODAL_GPU_COUNT=1

# GPU model: T4, L4, A10, L40S, A100-40GB, A100-80GB, H100, H200, B200
MODAL_GPU_MODEL="A10"
